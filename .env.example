DB_NAME=taller_db
DB_USER=taller_user
DB_PASSWORD=change_me
# Opción alternativa para proveedores cloud (Neon, Supabase, etc.)
# Si está definida, tiene prioridad sobre DB_HOST/DB_USER/DB_PASSWORD/DB_NAME/DB_PORT.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Puerto del servidor Postgres (dentro de Docker el backend usa 5432; esto es para tools en el host)
DB_PORT=5432
# Solo Docker Compose dev: puerto en tu PC para acceder a la DB (evita choque con Postgres local en 5432)
DB_PUBLISH_PORT=5433
# Host de Postgres: `db` en Docker Compose; `127.0.0.1` si conectás desde el host (usá DB_PUBLISH_PORT)
DB_HOST=127.0.0.1

JWT_SECRET=change_me_jwt_secret

# Credenciales del primer admin (se crean automáticamente si no existe)
ADMIN_EMAIL=admin@taller.com
ADMIN_PASSWORD=change_me_admin_password

# Origen permitido para CORS (frontend)
CORS_ORIGIN=http://localhost:5173

# API base que consumirá el navegador
VITE_API_URL=http://localhost:4000

